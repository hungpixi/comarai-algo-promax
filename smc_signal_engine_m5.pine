// SMC Signal Engine — Pine Script v6
// Faithful replica of hungpixi/xauusd-smc-signal-engine (Python XGBoost + SMC)
// Designed for M5 XAUUSD — EV+0.183R, 78% months profitable, 82% pass quỹ
//
// By: Pham Phu Nguyen Hung (Comarai)
// GitHub: https://github.com/hungpixi
// Website: https://comarai.com

//@version=6
indicator("SMC Signal Engine M5", shorttitle="SMC-M5", overlay=true,
     max_boxes_count=500, max_lines_count=500, max_labels_count=500)

// ═══════════════════════════════════════════════════════════════════
// INPUTS — Matching Python signal_engine_v2.py parameters exactly
// ═══════════════════════════════════════════════════════════════════
grp_core = "Core Strategy"
grp_smc  = "SMC Features"
grp_risk = "Risk Management"
grp_viz  = "Visuals"

// Core Strategy
i_sma_fast   = input.int(50, "SMA Fast (Trend)", group=grp_core)
i_sma_slow   = input.int(200, "SMA Slow (Trend)", group=grp_core)
i_session_start = input.int(7, "Session Start Hour (UTC)", minval=0, maxval=23, group=grp_core)
i_session_end   = input.int(21, "Session End Hour (UTC)", minval=0, maxval=23, group=grp_core)
i_rsi_len    = input.int(14, "RSI Length", group=grp_core)
i_rej_wick   = input.float(0.5, "Min Rejection Wick (×ATR)", step=0.1, group=grp_core, tooltip="Candle must show rejection via wick >= this × ATR")
i_vol_spike  = input.float(1.2, "Volume Spike Threshold", step=0.1, group=grp_core, tooltip="Volume must be >= this × SMA20 volume")

// SMC — from Python: swing_lookback=5, OB ATR threshold=1.5, FVG detection
i_swing_lb   = input.int(5, "Swing Lookback", minval=2, group=grp_smc)
i_ob_atr_mult= input.float(1.5, "OB Impulse ATR Multiplier", step=0.1, group=grp_smc)
i_fvg_lb     = input.int(10, "FVG Active Lookback", minval=1, group=grp_smc)
i_show_fvg   = input.bool(true, "Show FVG Zones", group=grp_smc)
i_show_ob    = input.bool(true, "Show Order Blocks", group=grp_smc)

// Risk — ATR-based SL (adaptive to any price level)
// Python used 2-5 price fixed on $2070 gold ≈ 0.5-1.2× M5 ATR
i_sl_atr_min = input.float(0.5, "Min SL (×ATR)", step=0.1, group=grp_risk)
i_sl_atr_max = input.float(3.0, "Max SL (×ATR)", step=0.1, group=grp_risk)
i_rr         = input.float(1.5, "Risk:Reward Ratio", step=0.1, group=grp_risk)
i_max_hold   = input.int(30, "Max Bars to Hold", group=grp_risk)
i_sl_lookback= input.int(20, "SL Swing Lookback", minval=5, group=grp_risk)

// Visuals
i_show_labels= input.bool(true, "Show Signal Labels", group=grp_viz)
i_show_sl_tp = input.bool(true, "Show SL/TP Lines", group=grp_viz)
i_show_stats = input.bool(true, "Show Stats Panel", group=grp_viz)
i_bull_col   = input.color(color.new(color.teal, 75), "Bull Zone Color", group=grp_viz)
i_bear_col   = input.color(color.new(color.maroon, 75), "Bear Zone Color", group=grp_viz)

// ═══════════════════════════════════════════════════════════════════
// 1. BASE FEATURES — Replicating add_base_features() from Python
// ═══════════════════════════════════════════════════════════════════
body      = close - open
rng       = high - low
upper_wick= high - math.max(open, close)
lower_wick= math.min(open, close) - low
atr_14    = ta.sma(rng, 14)
body_atr  = math.abs(body) / atr_14
range_atr = rng / atr_14

// RSI 14
rsi_14 = ta.rsi(close, i_rsi_len)

// Volume Ratio
vol_sma20 = ta.sma(volume, 20)
vol_ratio = vol_sma20 > 0 ? volume / vol_sma20 : 1.0

// Trend: SMA50 > SMA200
sma_fast = ta.sma(close, i_sma_fast)
sma_slow = ta.sma(close, i_sma_slow)
trend_up = sma_fast > sma_slow

// Session Filter
cur_hour   = hour(time, "Etc/UTC")
is_active  = cur_hour >= i_session_start and cur_hour < i_session_end

// Candle Pattern Detection
is_bull_rejection = lower_wick > atr_14 * i_rej_wick and lower_wick > upper_wick * 1.5
is_bear_rejection = upper_wick > atr_14 * i_rej_wick and upper_wick > lower_wick * 1.5
is_bull_engulf = close > open and close > high[1] and open <= close[1]
is_bear_engulf = close < open and close < low[1] and open >= close[1]
has_vol_spike = vol_ratio >= i_vol_spike

// ═══════════════════════════════════════════════════════════════════
// 2. SMC FEATURES — Replicating smc_features.py
// ═══════════════════════════════════════════════════════════════════

// --- 2a. Swing High / Low Detection (find_swing_points, lookback=5) ---
swing_hi_val = ta.highest(high, i_swing_lb * 2 + 1)
swing_lo_val = ta.lowest(low, i_swing_lb * 2 + 1)
is_swing_high = high[i_swing_lb] == swing_hi_val
is_swing_low  = low[i_swing_lb] == swing_lo_val

// Track recent swings for structural SL
var float last_swing_low  = na
var float last_swing_high = na
if is_swing_low[i_swing_lb]
    last_swing_low := low[i_swing_lb]
if is_swing_high[i_swing_lb]
    last_swing_high := high[i_swing_lb]

// --- 2b. Market Structure (HH/HL vs LH/LL) ---
var float prev_swing_high = na
var float prev_swing_low  = na
var int   ms_structure    = 0  // 1=Bullish, -1=Bearish, 0=Neutral

if is_swing_high[i_swing_lb]
    bool hh = not na(prev_swing_high) ? high[i_swing_lb] > prev_swing_high : false
    prev_swing_high := high[i_swing_lb]
    if hh
        ms_structure := 1

if is_swing_low[i_swing_lb]
    bool ll = not na(prev_swing_low) ? low[i_swing_lb] < prev_swing_low : false
    prev_swing_low := low[i_swing_lb]
    if ll
        ms_structure := -1

// --- 2c. Fair Value Gap Detection (find_fair_value_gaps) ---
// Bullish FVG: Low[0] > High[2] (gap up, middle candle is impulse)
// Bearish FVG: High[0] < Low[2] (gap down)
bull_fvg = low > high[2] and close[1] > open[1]
bear_fvg = high < low[2] and close[1] < open[1]

// FVG active within lookback
bull_fvg_active = ta.barssince(bull_fvg) <= i_fvg_lb
bear_fvg_active = ta.barssince(bear_fvg) <= i_fvg_lb

// Draw FVG zones
if i_show_fvg and bull_fvg
    box.new(bar_index[2], high[2], bar_index, low,
         bgcolor=color.new(color.green, 92), border_color=color.new(color.green, 100))
if i_show_fvg and bear_fvg
    box.new(bar_index[2], low[2], bar_index, high,
         bgcolor=color.new(color.red, 92), border_color=color.new(color.red, 100))

// --- 2d. Order Block Detection (find_order_blocks) ---
// Bullish OB: bearish candle[1] followed by bullish impulse[0] with range >= ATR*1.5
is_bull_impulse = close > open and rng >= i_ob_atr_mult * atr_14
bull_ob = is_bull_impulse and close[1] < open[1]

is_bear_impulse = close < open and rng >= i_ob_atr_mult * atr_14
bear_ob = is_bear_impulse and close[1] > open[1]

var array<box> bu_obs = array.new<box>(0)
var array<box> be_obs = array.new<box>(0)

if i_show_ob and bull_ob
    b = box.new(bar_index[1], open[1], bar_index + 10, low[1],
         bgcolor=i_bull_col, border_color=na,
         text="OB+", text_color=color.teal, text_size=size.tiny)
    array.push(bu_obs, b)
    if array.size(bu_obs) > 5
        box.delete(array.shift(bu_obs))

if i_show_ob and bear_ob
    b = box.new(bar_index[1], high[1], bar_index + 10, close[1],
         bgcolor=i_bear_col, border_color=na,
         text="OB−", text_color=color.maroon, text_size=size.tiny)
    array.push(be_obs, b)
    if array.size(be_obs) > 5
        box.delete(array.shift(be_obs))

// Extend / mitigate OBs
for b in bu_obs
    if close < box.get_bottom(b)
        box.set_bgcolor(b, color.new(color.gray, 93))
    else
        box.set_right(b, bar_index + 5)

for b in be_obs
    if close > box.get_top(b)
        box.set_bgcolor(b, color.new(color.gray, 93))
    else
        box.set_right(b, bar_index + 5)

// --- 2e. Distance Features (normalized by ATR) ---
dist_swing_low  = not na(last_swing_low) and atr_14 > 0 ? (close - last_swing_low) / atr_14 : 0.0
dist_swing_high = not na(last_swing_high) and atr_14 > 0 ? (last_swing_high - close) / atr_14 : 0.0

// ═══════════════════════════════════════════════════════════════════
// 3. SIGNAL LOGIC — Smart Money Concepts Confluence Entry
// ═══════════════════════════════════════════════════════════════════
// XGBoost showed FVG is the #1 feature (32.1% importance).
// Instead of crude RSI proxy, we require CONFLUENCE:
//   1. Trend alignment (SMA50 vs SMA200)
//   2. Price near FVG or OB zone (within lookback)
//   3. Candle rejection (long wick) OR engulfing pattern
//   4. Volume above average (confirmation)
//   5. RSI filter (avoid chasing into extremes)
//   6. Valid structural SL distance

// Structural SL — find nearest swing within lookback window
recent_swing_low  = ta.lowest(low, i_sl_lookback)
recent_swing_high = ta.highest(high, i_sl_lookback)

sl_long  = not na(last_swing_low) ? math.min(last_swing_low, recent_swing_low) - atr_14 * 0.1 : recent_swing_low - atr_14 * 0.1
sl_short = not na(last_swing_high) ? math.max(last_swing_high, recent_swing_high) + atr_14 * 0.1 : recent_swing_high + atr_14 * 0.1

sl_dist_long  = math.abs(close - sl_long)
sl_dist_short = math.abs(sl_short - close)

// SL distance filter: ATR-based
sl_ok_long  = atr_14 > 0 and sl_dist_long >= atr_14 * i_sl_atr_min and sl_dist_long <= atr_14 * i_sl_atr_max
sl_ok_short = atr_14 > 0 and sl_dist_short >= atr_14 * i_sl_atr_min and sl_dist_short <= atr_14 * i_sl_atr_max

// Entry trigger: candle rejection OR engulfing
bull_trigger = is_bull_rejection or is_bull_engulf
bear_trigger = is_bear_rejection or is_bear_engulf

// RSI filter: avoid chasing (not overbought for longs, not oversold for shorts)
rsi_ok_long  = rsi_14 > 30 and rsi_14 < 65
rsi_ok_short = rsi_14 > 35 and rsi_14 < 70

// CONFLUENCE: ALL conditions must be true
long_signal  = is_active and trend_up and bull_fvg_active and bull_trigger and has_vol_spike and rsi_ok_long and sl_ok_long
short_signal = is_active and not trend_up and bear_fvg_active and bear_trigger and has_vol_spike and rsi_ok_short and sl_ok_short

// State machine: one trade at a time
var int sig_state = 0
if long_signal and sig_state == 0
    sig_state := 1
else if short_signal and sig_state == 0
    sig_state := -1

is_buy  = sig_state == 1 and sig_state[1] != 1
is_sell = sig_state == -1 and sig_state[1] != -1

// ═══════════════════════════════════════════════════════════════════
// 4. TRADE VISUALIZATION — Entry, SL, TP
// ═══════════════════════════════════════════════════════════════════
var float active_entry = na
var float active_sl    = na
var float active_tp    = na
var int   active_dir   = 0
var int   bars_in_trade= 0

// Close existing trade
if active_dir != 0
    bars_in_trade += 1
    bool hit_sl = active_dir == 1 ? low <= active_sl : high >= active_sl
    bool hit_tp = active_dir == 1 ? high >= active_tp : low <= active_tp
    bool timeout = bars_in_trade >= i_max_hold
    
    if hit_sl or hit_tp or timeout
        if i_show_labels
            result_text = hit_tp ? "✅ TP" : hit_sl ? "❌ SL" : "⏳ TO"
            result_col  = hit_tp ? color.teal : color.maroon
            label.new(bar_index, hit_tp ? active_tp : active_sl, result_text,
                 style=active_dir == 1 ? label.style_label_down : label.style_label_up,
                 color=result_col, textcolor=color.white, size=size.tiny)
        active_dir   := 0
        active_entry := na
        active_sl    := na
        active_tp    := na
        bars_in_trade:= 0
        sig_state    := 0  // Allow new signals after trade closes

// New signal entry
if is_buy and active_dir == 0
    active_entry := close
    active_sl    := sl_long
    active_tp    := close + sl_dist_long * i_rr
    active_dir   := 1
    bars_in_trade:= 0
    
    if i_show_labels
        label.new(bar_index, low - atr_14 * 0.5,
             "BUY\nSL:" + str.tostring(active_sl, "#.##") + "\nTP:" + str.tostring(active_tp, "#.##"),
             style=label.style_label_up, color=color.teal,
             textcolor=color.white, size=size.tiny)
    if i_show_sl_tp
        line.new(bar_index, active_sl, bar_index + i_max_hold, active_sl,
             color=color.red, style=line.style_dashed, width=1)
        line.new(bar_index, active_tp, bar_index + i_max_hold, active_tp,
             color=color.green, style=line.style_dashed, width=1)

if is_sell and active_dir == 0
    active_entry := close
    active_sl    := sl_short
    active_tp    := close - sl_dist_short * i_rr
    active_dir   := -1
    bars_in_trade:= 0
    
    if i_show_labels
        label.new(bar_index, high + atr_14 * 0.5,
             "SELL\nSL:" + str.tostring(active_sl, "#.##") + "\nTP:" + str.tostring(active_tp, "#.##"),
             style=label.style_label_down, color=color.maroon,
             textcolor=color.white, size=size.tiny)
    if i_show_sl_tp
        line.new(bar_index, active_sl, bar_index + i_max_hold, active_sl,
             color=color.red, style=line.style_dashed, width=1)
        line.new(bar_index, active_tp, bar_index + i_max_hold, active_tp,
             color=color.green, style=line.style_dashed, width=1)

// ═══════════════════════════════════════════════════════════════════
// 5. TREND & SESSION OVERLAY
// ═══════════════════════════════════════════════════════════════════
plot(sma_fast, "SMA 50", color=color.new(color.blue, 50), linewidth=1)
plot(sma_slow, "SMA 200", color=color.new(color.orange, 50), linewidth=2)

// Session background
bgcolor(is_active ? color.new(color.white, 97) : color.new(color.gray, 95), 
     title="Session BG")

// Signal flash
bgcolor(is_buy ? color.new(color.teal, 90) : is_sell ? color.new(color.maroon, 90) : na,
     title="Signal Flash")

// ═══════════════════════════════════════════════════════════════════
// 6. STATISTICS PANEL — Live dashboard
// ═══════════════════════════════════════════════════════════════════
var int win_count  = 0
var int loss_count = 0

// Track outcomes
if active_dir[1] != 0 and active_dir == 0
    if active_dir[1] == 1
        if high[1] >= active_tp[1]
            win_count += 1
        else
            loss_count += 1
    else
        if low[1] <= active_tp[1]
            win_count += 1
        else
            loss_count += 1

if i_show_stats and barstate.islast
    int total = win_count + loss_count
    float wr  = total > 0 ? win_count / total * 100 : 0.0
    float ev  = total > 0 ? (win_count / total) * i_rr - (loss_count / total) : 0.0
    
    var table tb = table.new(position.top_right, 2, 8,
         bgcolor=color.new(#1a1a2e, 15),
         border_color=color.new(color.gray, 70), border_width=1)
    
    table.cell(tb, 0, 0, "SMC Engine M5", text_color=color.white, text_size=size.small)
    table.cell(tb, 1, 0, "v6 Live", text_color=color.gray, text_size=size.tiny)
    
    table.cell(tb, 0, 1, "Trend", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 1, trend_up ? "▲ BULL" : "▼ BEAR",
         text_color=trend_up ? color.teal : color.maroon, text_size=size.small)
    
    table.cell(tb, 0, 2, "Session", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 2, is_active ? "🟢 Active" : "🔴 Off",
         text_color=is_active ? color.green : color.red, text_size=size.tiny)
    
    table.cell(tb, 0, 3, "RSI", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 3, str.tostring(rsi_14, "#.0"),
         text_color=rsi_14 > i_rsi_ob ? color.red : rsi_14 < i_rsi_os ? color.green : color.white,
         text_size=size.small)
    
    table.cell(tb, 0, 4, "FVG", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 4,
         bull_fvg_active and bear_fvg_active ? "Bull+Bear" :
         bull_fvg_active ? "Bull ✓" : bear_fvg_active ? "Bear ✓" : "—",
         text_color=bull_fvg_active ? color.teal : bear_fvg_active ? color.maroon : color.gray,
         text_size=size.tiny)
    
    table.cell(tb, 0, 5, "Trades", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 5, str.tostring(total) + " (W:" + str.tostring(win_count) + " L:" + str.tostring(loss_count) + ")",
         text_color=color.white, text_size=size.tiny)
    
    table.cell(tb, 0, 6, "Winrate", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 6, str.tostring(wr, "#.1") + "%",
         text_color=wr >= 47 ? color.teal : color.maroon, text_size=size.small)
    
    table.cell(tb, 0, 7, "EV/R", text_color=color.gray, text_size=size.tiny)
    table.cell(tb, 1, 7, str.tostring(ev, "+#.###") + "R",
         text_color=ev > 0 ? color.teal : color.maroon, text_size=size.small)

// ═══════════════════════════════════════════════════════════════════
// 7. ALERTS (JSON for n8n / Webhook / Telegram)
// ═══════════════════════════════════════════════════════════════════
alertcondition(is_buy, title="SMC Engine: BUY",
     message='{"action":"BUY","symbol":"{{ticker}}","price":{{close}},"tf":"{{interval}}"}')
alertcondition(is_sell, title="SMC Engine: SELL",
     message='{"action":"SELL","symbol":"{{ticker}}","price":{{close}},"tf":"{{interval}}"}')
