// Comarai Algo ProMax v6 — SMC + Trend + XGBoost Proxy ML
// By: Pham Phu Nguyen Hung (Comarai)
// GitHub: https://github.com/hungpixi
// Website: https://comarai.com
// Based on: hungpixi/xauusd-smc-signal-engine (XGBoost + SMC)

//@version=6
indicator("Comarai Algo ProMax v6", shorttitle="CmrPM v6", overlay=true,
     max_boxes_count=500, max_lines_count=500, max_labels_count=200)

// =========================================================================
// 1. SETTINGS & INPUTS
// =========================================================================
grp_trend   = "1. Trend Filters"
grp_smc     = "2. Smart Money Concepts"
grp_ml      = "3. Proxy ML Trigger"
grp_display = "4. Display & Styling"
grp_stats   = "5. Statistics Panel"

// -- Trend Inputs
ma_type     = input.string("EMA", "MA Type", options=["EMA","SMA","WMA","HullMA","VWMA","RMA"], group=grp_trend)
ma_len      = input.int(200, "Trend MA Length", minval=10, group=grp_trend)
use_trend   = input.bool(true, "Use Trend Filter?", group=grp_trend)

// -- SMC Inputs
zigzag_len  = input.int(9, "Swing Detection Length", minval=3, group=grp_smc)
show_zz     = input.bool(false, "Show ZigZag Lines", group=grp_smc)
fib_factor  = input.float(0.33, "Fib Factor for Breakout", minval=0.0, maxval=1.0, step=0.01, group=grp_smc)
show_fvg    = input.bool(true, "Show FVG Zones", group=grp_smc)
show_ob     = input.bool(true, "Show Order Blocks", group=grp_smc)
ob_max      = input.int(5, "Max Active OBs", minval=1, maxval=20, group=grp_smc)

// -- ML Trigger Inputs
rsi_len     = input.int(14, "RSI Length", group=grp_ml)
rsi_ob      = input.int(60, "RSI Overbought", group=grp_ml)
rsi_os      = input.int(40, "RSI Oversold", group=grp_ml)
fvg_lookback= input.int(10, "FVG Lookback Bars", minval=1, group=grp_ml)
sl_atr_min  = input.float(0.5, "Min SL Distance (×ATR)", step=0.1, group=grp_ml)

// -- Display Inputs
show_labels = input.bool(true, "Show Buy/Sell Labels", group=grp_display)
show_stats  = input.bool(true, "Show Stats Panel", group=grp_stats)
ob_bull_col = input.color(color.new(color.teal, 80), "Bullish OB", group=grp_display)
ob_bear_col = input.color(color.new(color.maroon, 80), "Bearish OB", group=grp_display)
fvg_bull_col= input.color(color.new(color.green, 90), "Bull FVG", group=grp_display)
fvg_bear_col= input.color(color.new(color.red, 90), "Bear FVG", group=grp_display)

// =========================================================================
// 2. TREND FILTER — Multi-MA Support
// =========================================================================
calc_ma(src, len, typ) =>
    switch typ
        "SMA"    => ta.sma(src, len)
        "WMA"    => ta.wma(src, len)
        "HullMA" => ta.hma(src, len)
        "VWMA"   => ta.vwma(src, len)
        "RMA"    => ta.rma(src, len)
        =>          ta.ema(src, len)

trend_ma     = calc_ma(close, ma_len, ma_type)
is_uptrend   = close > trend_ma
is_downtrend = close < trend_ma

ma_color = is_uptrend ? color.teal : color.maroon
plot(trend_ma, color=ma_color, title="Trend MA", linewidth=2)

// =========================================================================
// 3. SMC: FAIR VALUE GAPS (FVG)
// =========================================================================
is_bull_fvg = low > high[2] and close[1] > open[1]
is_bear_fvg = high < low[2] and close[1] < open[1]

if show_fvg and is_bull_fvg
    box.new(bar_index[2], high[2], bar_index, low,
         bgcolor=fvg_bull_col, border_color=color.new(color.green, 100))

if show_fvg and is_bear_fvg
    box.new(bar_index[2], low[2], bar_index, high,
         bgcolor=fvg_bear_col, border_color=color.new(color.red, 100))

// =========================================================================
// 4. SMC: MARKET STRUCTURE BREAK (MSB) & ORDER BLOCKS (OB)
// =========================================================================
var array<float> sv_highs   = array.new<float>(5)
var array<int>   sv_high_ix = array.new<int>(5)
var array<float> sv_lows    = array.new<float>(5)
var array<int>   sv_low_ix  = array.new<int>(5)

var array<box> bu_ob_boxes = array.new<box>(0)
var array<box> be_ob_boxes = array.new<box>(0)

to_up   = high >= ta.highest(zigzag_len)
to_down = low  <= ta.lowest(zigzag_len)

var int zz_trend = 1
zz_trend := zz_trend == 1 and to_down ? -1
         : zz_trend == -1 and to_up  ?  1
         : nz(zz_trend[1], 1)

last_to_up   = ta.barssince(to_up[1])
safe_lu      = nz(last_to_up > 0 ? last_to_up : 1, 1)
low_val      = ta.lowest(safe_lu)
low_i        = bar_index - ta.barssince(low_val == low)

last_to_down = ta.barssince(to_down[1])
safe_ld      = nz(last_to_down > 0 ? last_to_down : 1, 1)
high_val     = ta.highest(safe_ld)
high_i       = bar_index - ta.barssince(high_val == high)

if ta.change(zz_trend) != 0
    if zz_trend == 1
        array.push(sv_lows,   low_val)
        array.push(sv_low_ix, low_i)
    if zz_trend == -1
        array.push(sv_highs,   high_val)
        array.push(sv_high_ix, high_i)

// Helper: get swing value by index from end
get_swing(arr, ix_arr, idx) =>
    int sz = array.size(arr)
    float val = na
    int   pos = na
    if sz > idx
        val := array.get(arr, sz - 1 - idx)
        pos := array.get(ix_arr, sz - 1 - idx)
    [val, pos]

[h0, h0i] = get_swing(sv_highs, sv_high_ix, 0)
[h1, h1i] = get_swing(sv_highs, sv_high_ix, 1)
[l0, l0i] = get_swing(sv_lows,  sv_low_ix,  0)
[l1, l1i] = get_swing(sv_lows,  sv_low_ix,  1)

// ZigZag visualization
if ta.change(zz_trend) != 0 and show_zz
    if zz_trend == 1 and not na(h0) and not na(l0i)
        line.new(h0i, h0, l0i, l0,
             color=color.gray, style=line.style_dotted)
    if zz_trend == -1 and not na(l0) and not na(h0i)
        line.new(l0i, l0, h0i, h0,
             color=color.gray, style=line.style_dotted)

// Market structure detection
var int market = 1
last_l0 = ta.valuewhen(ta.change(market) != 0, l0, 0)
last_h0 = ta.valuewhen(ta.change(market) != 0, h0, 0)

new_mkt = last_l0 == l0 or last_h0 == h0
         ? nz(market[1], 1)
         : market == 1 and not na(l0) and not na(l1) and not na(h0)
           and l0 < l1 and l0 < l1 - math.abs(h0 - l1) * fib_factor
         ? -1
         : market == -1 and not na(h0) and not na(h1) and not na(l0)
           and h0 > h1 and h0 > h1 + math.abs(h1 - l0) * fib_factor
         ?  1
         : nz(market[1], 1)
market := new_mkt

// -- Order Block creation on MSB
if show_ob and ta.change(market) != 0 and market == 1 and not na(h1) and not na(l0i)
    int found_idx = na
    int search_end = math.max(nz(l0i, 0), 1)
    for k = nz(h1i, 0) to search_end
        int offset = bar_index - k
        if offset > 0 and offset < bar_index and open[offset] > close[offset]
            found_idx := k
            break
    if not na(found_idx)
        int off = bar_index - found_idx
        b = box.new(found_idx, high[off], bar_index + 15, low[off],
             bgcolor=ob_bull_col, border_color=na,
             text="OB+", text_color=color.teal, text_size=size.tiny)
        array.push(bu_ob_boxes, b)
        if array.size(bu_ob_boxes) > ob_max
            box.delete(array.shift(bu_ob_boxes))

if show_ob and ta.change(market) != 0 and market == -1 and not na(l1) and not na(h0i)
    int found_idx = na
    int search_end = math.max(nz(h0i, 0), 1)
    for k = nz(l1i, 0) to search_end
        int offset = bar_index - k
        if offset > 0 and offset < bar_index and open[offset] < close[offset]
            found_idx := k
            break
    if not na(found_idx)
        int off = bar_index - found_idx
        b = box.new(found_idx, high[off], bar_index + 15, low[off],
             bgcolor=ob_bear_col, border_color=na,
             text="OB−", text_color=color.maroon, text_size=size.tiny)
        array.push(be_ob_boxes, b)
        if array.size(be_ob_boxes) > ob_max
            box.delete(array.shift(be_ob_boxes))

// Extend / mitigate active OBs
for b in bu_ob_boxes
    if close < box.get_bottom(b)
        box.set_bgcolor(b, color.new(color.gray, 92))
    else
        box.set_right(b, bar_index + 5)

for b in be_ob_boxes
    if close > box.get_top(b)
        box.set_bgcolor(b, color.new(color.gray, 92))
    else
        box.set_right(b, bar_index + 5)

// =========================================================================
// 5. PROXY ML TRIGGER (RSI + FVG + Structural SL Distance)
// =========================================================================
_rsi = ta.rsi(close, rsi_len)
_atr = ta.atr(14)

prox_bull_fvg = ta.barssince(is_bull_fvg) <= fvg_lookback
prox_bear_fvg = ta.barssince(is_bear_fvg) <= fvg_lookback

// Core conditions
trend_ok_long  = not use_trend or is_uptrend
trend_ok_short = not use_trend or is_downtrend

long_cond  = trend_ok_long  and _rsi < rsi_os and prox_bull_fvg
short_cond = trend_ok_short and _rsi > rsi_ob and prox_bear_fvg

// Structural SL distance check (XGBoost insight: avoid entries with SL too tight)
sl_dist_ok_long  = not na(l0) ? (close - l0) > _atr * sl_atr_min : false
sl_dist_ok_short = not na(h0) ? (h0 - close) > _atr * sl_atr_min : false

long_cond  := long_cond  and sl_dist_ok_long
short_cond := short_cond and sl_dist_ok_short

// Signal state machine
var int signal = 0
if long_cond and signal <= 0
    signal := 1
else if short_cond and signal >= 0
    signal := -1

// Reset to neutral for re-entry
if _rsi > 50 and signal == 1
    signal := 0
if _rsi < 50 and signal == -1
    signal := 0

is_new_long  = signal ==  1 and signal[1] <= 0
is_new_short = signal == -1 and signal[1] >= 0

// =========================================================================
// 6. VISUAL SIGNALS
// =========================================================================
if show_labels and is_new_long
    label.new(bar_index, low - _atr * 0.5, "BUY\n(SMC)",
         style=label.style_label_up, color=color.teal,
         textcolor=color.white, size=size.small)

if show_labels and is_new_short
    label.new(bar_index, high + _atr * 0.5, "SELL\n(SMC)",
         style=label.style_label_down, color=color.maroon,
         textcolor=color.white, size=size.small)

// Background flash on signal
bgcolor(is_new_long  ? color.new(color.teal, 92) :
        is_new_short ? color.new(color.maroon, 92) : na,
        title="Signal Flash")

// =========================================================================
// 7. STATISTICS PANEL
// =========================================================================
var int total_long  = 0
var int total_short = 0
if is_new_long
    total_long += 1
if is_new_short
    total_short += 1

if show_stats and barstate.islast
    var table stats = table.new(position.top_right, 2, 5,
         bgcolor=color.new(color.black, 85),
         border_color=color.new(color.gray, 70),
         border_width=1)
    table.cell(stats, 0, 0, "Comarai PM v6",
         text_color=color.white, text_size=size.small)
    table.cell(stats, 1, 0, ma_type + " " + str.tostring(ma_len),
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 0, 1, "Trend",
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 1, is_uptrend ? "▲ BULL" : "▼ BEAR",
         text_color=is_uptrend ? color.teal : color.maroon,
         text_size=size.small)
    table.cell(stats, 0, 2, "RSI " + str.tostring(rsi_len),
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 2, str.tostring(_rsi, "#.0"),
         text_color=_rsi > rsi_ob ? color.red : _rsi < rsi_os ? color.green : color.white,
         text_size=size.small)
    table.cell(stats, 0, 3, "Longs",
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 3, str.tostring(total_long),
         text_color=color.teal, text_size=size.small)
    table.cell(stats, 0, 4, "Shorts",
         text_color=color.gray, text_size=size.tiny)
    table.cell(stats, 1, 4, str.tostring(total_short),
         text_color=color.maroon, text_size=size.small)

// =========================================================================
// 8. ALERTS (JSON for n8n / Webhook)
// =========================================================================
alertcondition(is_new_long,  title="Comarai PM: BUY",
     message='{"action":"BUY","symbol":"{{ticker}}","price":{{close}},"tf":"{{interval}}"}')
alertcondition(is_new_short, title="Comarai PM: SELL",
     message='{"action":"SELL","symbol":"{{ticker}}","price":{{close}},"tf":"{{interval}}"}')
